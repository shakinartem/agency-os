FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir alembic sqlalchemy psycopg2-binary asyncpg python-dotenv "sqlalchemy[asyncio]" pydantic-settings

COPY .env .env
COPY packages/ ./packages/
COPY integrations/ ./integrations/

ENV DATABASE_URL=postgresql+psycopg2://agency:agency_secret@postgres:5432/agency_os
ENV PYTHONPATH=/app/packages:/app/integrations

WORKDIR /app/packages/database

CMD ["alembic", "upgrade", "head"]
